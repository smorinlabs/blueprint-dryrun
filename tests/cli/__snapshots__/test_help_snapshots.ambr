# ---
# name: test_help_snapshot[bpd config set]
  '''
  Usage: bpd config set [OPTIONS] {logging.file|logging.file_level|logging.format|
                        logging.level|output.color|output.format} VALUE
  
    Write a non-secret config value to the TOML config file.
  
    KEY is a dotted path into the config tables. Examples:     bpd config set
    output.color always     bpd config set logging.level info     bpd config set
    logging.file_level debug --yes
  
    Secrets are never stored here — supply the token via --token or $BPD_TOKEN.
    Prompts before overwriting an existing value unless --yes.
  
  Options:
    --dry-run                       Show what would change; write nothing.
    -y, --yes                       Skip confirmation prompts (for scripts/CI).
    -o, --output [text|json|markdown]
                                    Output format. [default: text]
    --json                          Shorthand for --output json.
    --output-file FILE              Write results to a file instead of stdout
                                    (format set by --output).
    -v, --verbose                   Increase log verbosity (-vv for debug).
    -q, --quiet                     Suppress non-essential stderr output.
    --log-level [debug|info|warning|error|critical]
                                    Explicit console log level (overrides -v/-q).
    --log-file TEXT                 Enable rotating file logging (PATH optional;
                                    default: XDG state).
    --no-color                      Disable colored output.
    --config FILE                   Path to a TOML config file (overrides layered
                                    discovery).
    --token TEXT                    Py Personal Access Token (overrides
                                    $BPD_TOKEN). Never stored.
    --no-input                      Never prompt; fail instead (for scripts/CI).
    -h, --help                      Show this message and exit.
  
  '''
# ---
# name: test_help_snapshot[bpd config]
  '''
  Usage: bpd config [OPTIONS] COMMAND [ARGS]...
  
    Inspect and edit CLI configuration.
  
  Options:
    -h, --help  Show this message and exit.
  
  Commands:
    get   Show a resolved config value and where it came from.
    init  Create or update the config file with guided prompts.
    path  Show the config file path and whether it exists.
    set   Write a non-secret config value to the TOML config file.
  
  '''
# ---
# name: test_help_snapshot[bpd doctor]
  '''
  Usage: bpd doctor [OPTIONS]
  
    Diagnose configuration and environment.
  
    Reports Python/platform, the resolved config file, and token status. Exits
    non-zero if any check is an error (useful in CI). Honors -o/--json. --bundle
    widens the report into a redacted snapshot (version, settings, app env vars
    with secrets masked) safe to paste into a public issue.
  
  Options:
    --bundle                        Emit a redacted diagnostics bundle to attach
                                    to bug reports.
    -o, --output [text|json|markdown]
                                    Output format. [default: text]
    --json                          Shorthand for --output json.
    --output-file FILE              Write results to a file instead of stdout
                                    (format set by --output).
    -v, --verbose                   Increase log verbosity (-vv for debug).
    -q, --quiet                     Suppress non-essential stderr output.
    --log-level [debug|info|warning|error|critical]
                                    Explicit console log level (overrides -v/-q).
    --log-file TEXT                 Enable rotating file logging (PATH optional;
                                    default: XDG state).
    --no-color                      Disable colored output.
    --config FILE                   Path to a TOML config file (overrides layered
                                    discovery).
    --token TEXT                    Py Personal Access Token (overrides
                                    $BPD_TOKEN). Never stored.
    --no-input                      Never prompt; fail instead (for scripts/CI).
    -h, --help                      Show this message and exit.
  
  '''
# ---
