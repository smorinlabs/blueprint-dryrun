# name: test_help_snapshot[bpd projects list]
  '''
  Usage: bpd projects list [OPTIONS]
  
    List projects, optionally filtered by workspace.
  
    Examples:     bpd projects list     bpd projects list --workspace "My
    Workspace" --json     bpd projects list -o markdown
  
  Options:
    --workspace TEXT                Filter projects by workspace name.
    --limit INTEGER RANGE           Maximum number of projects to retrieve.
                                    [default: 200; x>=1]
    -o, --output [text|json|markdown]
                                    Output format. [default: text]
    --json                          Shorthand for --output json.
    --output-file FILE              Write results to a file instead of stdout
                                    (format set by --output).
    -v, --verbose                   Increase log verbosity (-vv for debug).
    -q, --quiet                     Suppress non-essential stderr output.
    --log-level [debug|info|warning|error|critical]
                                    Explicit console log level (overrides -v/-q).
    --log-file TEXT                 Enable rotating file logging (PATH optional;
                                    default: XDG state).
    --no-color                      Disable colored output.
    --config FILE                   Path to a TOML config file (overrides layered
                                    discovery).
    --token TEXT                    Py Personal Access Token (overrides
                                    $BPD_TOKEN). Never stored.
    --no-input                      Never prompt; fail instead (for scripts/CI).
    -h, --help                      Show this message and exit.
  
  '''
# ---
# name: test_help_snapshot[bpd projects]
  '''
  Usage: bpd projects [OPTIONS] COMMAND [ARGS]...
  
    List and inspect Py projects.
  
  Options:
    -h, --help  Show this message and exit.
  
  Commands:
    get   Fetch a single project by its ID.
    list  List projects, optionally filtered by workspace.
  
  '''
# ---
# name: test_help_snapshot[bpd]
  '''
  Usage: bpd [OPTIONS] COMMAND [ARGS]...
  
    bpd — a gh-style CLI for Py.
  
    Commands follow a noun-verb shape, e.g. `bpd projects list`. Every command
    supports -o/--output {text,json,markdown}, --json, -v/--verbose, --no-color,
    and --config. Results go to stdout; logs and errors go to stderr.
  
  Options:
    -V, --version  Show version, Python, and platform, then exit.
    -h, --help     Show this message and exit.
  
  Commands:
    completion  Print a shell completion script.
    config      Inspect and edit CLI configuration.
    doctor      Diagnose configuration and environment.
    projects    List and inspect Py projects.
  
  '''
# ---
